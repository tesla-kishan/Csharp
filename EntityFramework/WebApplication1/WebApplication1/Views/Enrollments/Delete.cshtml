@model WebApplication1.Models.Enrollment
@{
    ViewData["Title"] = "Delete Enrollment";
}

<div class="card">
    <div class="card-header"><h4>Remove Enrollment</h4></div>
    <div class="card-body">
        <h5>Are you sure you want to remove this enrollment?</h5>
        <div>
            <p><strong>Student:</strong> @Model.Student?.Name</p>
            <p><strong>Course:</strong> @Model.Course?.Title</p>
        </div>
        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger">Remove</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>
