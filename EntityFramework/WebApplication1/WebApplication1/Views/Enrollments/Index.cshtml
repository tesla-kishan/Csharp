@model IEnumerable<WebApplication1.Models.Enrollment>
@{
    ViewData["Title"] = "Enrollments";
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h4>Enrollments</h4>
        <div>
            <a class="btn btn-primary" asp-action="Create">New Enrollment</a>
        </div>
    </div>
    <div class="card-body">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>Student</th>
                    <th>Course</th>
                    <th>Enrollment Date</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Student?.Name</td>
                        <td>@item.Course?.Title</td>
                        <td>@item.EnrollmentDate.ToString("yyyy-MM-dd")</td>
                        <td>
                            <a class="btn btn-sm btn-danger" asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
