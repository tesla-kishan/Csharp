@model CRUD_Operations_using_MVC.Models.Application
@{
    ViewData["Title"] = "Details";
}

<h1>Application Details</h1>
<div>
    <h4>Application</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">Applicant</dt>
        <dd class = "col-sm-10">@Model.ApplicantName</dd>

        <dt class = "col-sm-2">Email</dt>
        <dd class = "col-sm-10">@Model.Email</dd>

        <dt class = "col-sm-2">Phone</dt>
        <dd class = "col-sm-10">@Model.Phone</dd>

        <dt class = "col-sm-2">Position</dt>
        <dd class = "col-sm-10">@Model.Position</dd>

        <dt class = "col-sm-2">Resume</dt>
        <dd class = "col-sm-10">@Model.ResumeText</dd>

        <dt class = "col-sm-2">Created</dt>
        <dd class = "col-sm-10">@Model.CreatedAt.ToString("u")</dd>
    </dl>
</div>
<p>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a> |
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</p>
