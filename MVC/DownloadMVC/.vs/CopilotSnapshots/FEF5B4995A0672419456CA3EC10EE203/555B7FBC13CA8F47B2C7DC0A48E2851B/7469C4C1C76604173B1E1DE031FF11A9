@model DownloadMVC.Models.CollegeApplication

<style>
    .id-card {
        width: 350px;
        margin: 50px auto;
        padding: 20px;
        background: linear-gradient(135deg,#141e30,#243b55);
        color: white;
        border-radius: 15px;
        text-align: center;
    }
    .id-card img {
        width:100px;
        height:100px;
        border-radius:50%;
        border:3px solid white;
    }
    .btn {
        display:inline-block;
        margin-top:15px;
        padding:8px 15px;
        background:white;
        color:#141e30;
        text-decoration:none;
        border-radius:5px;
    }
</style>

<div class="id-card">
    <img src="@Model.PhotoPath" />
    <h3>@Model.FirstName @Model.LastName</h3>
    <p>ID: @Model.Id</p>

    <a class="btn" href="/Application/DownloadPdf/@Model.Id">
        Download Application PDF
    </a>
    <a class="btn" href="/Application/DownloadIdCard/@Model.Id">
        Download ID Card
    </a>
</div>